# EEBus Device Configuration
# Copy this file to .env and fill in your device details

# Device Subject Key Identifier (SKI)
# This is a unique identifier for your EEBus device (40 hex characters)
# You can find this in your device's EEBus settings or documentation
EEBUS_DEVICE_SKI=your_device_ski_here

# Device IP Address
# The IP address of your EEBus device on your network
EEBUS_DEVICE_IP=192.168.1.100

# Device Port (optional, defaults to 4712)
# The port your EEBus device is listening on
# Common ports: 4712 (standard), 12480 (some heat pumps)
EEBUS_DEVICE_PORT=4712
